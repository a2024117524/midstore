@page "/Account/Manage/PersonalData"

@inject IdentityUserAccessor UserAccessor

<PageTitle>Personal data</PageTitle>

<MudContainer Style="background-color: #333333">
    <br />
    <MudText Typo="Typo.h3" GutterBottom="true">Manage personal data</MudText>
    <MudDivider />
    <StatusMessage />
    <br />
    <MudGrid>
        <MudItem md="12">
            <form action="Account/Manage/DownloadPersonalData" method="post">
                <AntiforgeryToken />
                <MudFab Color="Color.Primary" Label="Download Data" ButtonType="ButtonType.Submit" />
            </form>
        </MudItem>
        <MudItem md="12">
            <MudFab Color="Color.Secondary" Label="Delete Data" Href="Account/Manage/DeletePersonalData" />
        </MudItem>
    </MudGrid>
    <br />
</MudContainer>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _ = await UserAccessor.GetRequiredUserAsync(HttpContext);
    }
}