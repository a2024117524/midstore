@page "/"

@using System.Text
@using System.Text.Json
@using System.Security.Claims
@using MidStore.Components.Shared
@using MidStore.Data.Models

@inject HttpClient HttpClient
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Home</PageTitle>
<SearchBar @bind-MediaSearch="UploadedMedia" MediaInitSearch="UploadedMediaInitial"  />
<MudContainer Style="background-color: #333333">
    <br />
    <MudText Typo="Typo.h3" GutterBottom="true">Purchase new media</MudText>
    <MudDivider />
    <MudGrid>
        @foreach (var media in UploadedMedia)
        {
            <MudItem>
                <MudCard Style="background-color: #2c2c2c; border-width: 1px; border-color: #FBB86C">
                    <MudCardMedia Image="@media.Cover" />
                    <MudCardContent>
                        <MudText>Title: @media.Title</MudText>
                        <MudText>Description: @media.Description</MudText>
                        <MudText>Explicit: @media.Explicit</MudText>
                        <MudText>Uploaded On: @media.UploadDateTime</MudText>
                        <MudText>User: @media.UserName</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudFab Color="Color.Primary" Label="Add to library" OnClick="@(e=> AddMediaFile(media))" />
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
    <br />
</MudContainer>

@code {
    private string? UserId;
    private List<Media> Media { get; set; } = new List<Media>();
    [Parameter]
    public List<Media> UploadedMedia { get; set; } = new List<Media>();
    [Parameter]
    public List<Media> UploadedMediaInitial { get; set; } = new List<Media>();


    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        UserId = (user.FindFirst(ClaimTypes.NameIdentifier)?.Value);

        if (HttpClient != null)
        {
            var mediaContent = await HttpClient.GetFromJsonAsync<List<Media>>("https://localhost:7139/api/Media");

            Media = mediaContent ?? new List<Media>();
            UploadedMedia = Media.Where(m => m.Private == false && m.UserId != UserId || m.UserId == null)
                                 .OrderByDescending(m => m.UploadDateTime)
                                 .ToList();
            UploadedMediaInitial = Media.Where(m => m.Private == false && m.UserId != UserId || m.UserId == null)
                                 .OrderByDescending(m => m.UploadDateTime)
                                 .ToList();
        }
    }

    private async Task AddMediaFile(Media media)
    {
        Purchase Purchase = new Purchase()
        {
            MediaId = media.Id,
            UserId = UserId,
            PurchaseDateTime = DateTime.Now
        };
        var purchaseContent = new StringContent(JsonSerializer.Serialize(Purchase), Encoding.UTF8, "application/json");
        var purchaseResponse = await HttpClient.PostAsync("https://localhost:7139/api/Purchase", purchaseContent);
        NavigationManager.NavigateTo("/Library");
    }
   
}